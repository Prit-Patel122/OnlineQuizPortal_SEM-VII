@{
    ViewData["Title"] = "Access Denied";
}

<div class="text-center">
    <div class="card">
        <div class="card-body p-5">
            <i class="fas fa-exclamation-triangle fa-5x text-warning mb-4"></i>
            <h1 class="text-danger mb-4">Access Denied</h1>
            <p class="lead mb-4">Sorry, you don't have permission to access this resource.</p>
            <p class="text-muted mb-4">Please contact your administrator if you believe this is an error.</p>
            
            <div class="d-flex gap-3 justify-content-center flex-wrap">
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                    <i class="fas fa-home me-2"></i>Go to Home
                </a>
                <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary">
                    <i class="fas fa-sign-in-alt me-2"></i>Login
                </a>
            </div>
        </div>
    </div>
</div>
