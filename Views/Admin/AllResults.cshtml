@model List<OnlineQuizPortal.Models.Result>

@{
    ViewData["Title"] = "All Quiz Results";
}

<div class="container">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="text-center mb-4">
                <i class="fas fa-list-alt me-2"></i>All Quiz Results
            </h1>
        </div>
    </div>

    <div class="card">
        <div class="card-header bg-dark text-white">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="fas fa-table me-2"></i>Results List</h5>
                <div>
                    <button class="btn btn-sm btn-outline-light" onclick="exportToExcel()">
                        <i class="fas fa-file-excel me-2"></i>Export to Excel
                    </button>
                </div>
            </div>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover" id="resultsTable">
                    <thead class="table-dark">
                        <tr>
                            <th>Student Name</th>
                            <th>Quiz Title</th>
                            <th>Score</th>
                            <th>Start Time</th>
                            <th>Completion Time</th>
                            <th>Status</th>
                            <th>Duration</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var result in Model)
                        {
                            <tr>
                                <td>@result.User.Name</td>
                                <td>@result.Quiz.Title</td>
                                <td>@(result.IsCompleted ? $"{result.Score}/{result.Quiz.TotalMarks}" : "N/A")</td>
                                <td>@result.StartedAt.ToString("MMM dd, yyyy HH:mm")</td>
                                <td>@(result.CompletedAt?.ToString("MMM dd, yyyy HH:mm") ?? "Not Completed")</td>
                                <td>
                                    @if (result.IsCompleted)
                                    {
                                        <span class="badge bg-success">Completed</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning">In Progress</span>
                                    }
                                </td>
                                <td>
                                    @if (result.CompletedAt.HasValue)
                                    {
                                        var duration = result.CompletedAt.Value - result.StartedAt;
                                        @duration.ToString(@"hh\:mm\:ss")
                                    }
                                    else
                                    {
                                        <span>-</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/xlsx/dist/xlsx.full.min.js"></script>
    <script>
        $(document).ready(function () {
            // Initialize DataTables
            $('#resultsTable').DataTable({
                order: [[3, 'desc']], // Sort by Start Time by default
                pageLength: 25
            });
        });

        function exportToExcel() {
            const table = document.getElementById('resultsTable');
            const wb = XLSX.utils.table_to_book(table, { sheet: "Results" });
            XLSX.writeFile(wb, 'QuizResults.xlsx');
        }
    </script>
}
