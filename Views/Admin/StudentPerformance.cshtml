@{
    ViewData["Title"] = "Student Performance";
}

<div class="container">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="text-center mb-4">
                <i class="fas fa-user-graduate me-2"></i>Student Performance Analytics
            </h1>
        </div>
    </div>

    <div class="card">
        <div class="card-header bg-dark text-white">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="fas fa-chart-line me-2"></i>Performance Overview</h5>
                <div>
                    <button class="btn btn-sm btn-outline-light" onclick="exportToExcel()">
                        <i class="fas fa-file-excel me-2"></i>Export to Excel
                    </button>
                </div>
            </div>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover" id="performanceTable">
                    <thead class="table-dark">
                        <tr>
                            <th>Student Name</th>
                            <th>Total Attempts</th>
                            <th>Completed Quizzes</th>
                            <th>Average Score</th>
                            <th>Performance Level</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var performance in ViewBag.StudentPerformance)
                        {
                            <tr>
                                <td>@performance.User.Name</td>
                                <td>@performance.TotalAttempts</td>
                                <td>@performance.CompletedQuizzes</td>
                                <td>@performance.AverageScore.ToString("0.00")%</td>
                                <td>
                                    @{
                                        var level = performance.AverageScore switch
                                        {
                                            >= 90 => new { Class = "bg-success", Text = "Excellent" },
                                            >= 80 => new { Class = "bg-info", Text = "Very Good" },
                                            >= 70 => new { Class = "bg-primary", Text = "Good" },
                                            >= 60 => new { Class = "bg-warning", Text = "Average" },
                                            _ => new { Class = "bg-danger", Text = "Needs Improvement" }
                                        };
                                    }
                                    <span class="badge @level.Class">@level.Text</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Performance Charts -->
    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0"><i class="fas fa-chart-bar me-2"></i>Average Scores Distribution</h5>
                </div>
                <div class="card-body">
                    <canvas id="scoresChart"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0"><i class="fas fa-chart-pie me-2"></i>Completion Rates</h5>
                </div>
                <div class="card-body">
                    <canvas id="completionChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        $(document).ready(function () {
            // Initialize DataTable
            $('#performanceTable').DataTable({
                order: [[3, 'desc']], // Sort by Average Score by default
                pageLength: 25
            });

            // Get data from ViewBag
            var performanceData = @Html.Raw(Json.Serialize(ViewBag.StudentPerformance));
            var students = performanceData.map(function(p) { return p.User.Name; });
            var averageScores = performanceData.map(function(p) { return p.AverageScore; });
            var completionRates = performanceData.map(function(p) { 
                return p.TotalAttempts > 0 ? (p.CompletedQuizzes * 100.0 / p.TotalAttempts) : 0;
            });

            // Create Score Distribution Chart
            new Chart(document.getElementById('scoresChart'), {
                type: 'bar',
                data: {
                    labels: students,
                    datasets: [{
                        label: 'Average Score (%)',
                        data: averageScores,
                        backgroundColor: 'rgba(54, 162, 235, 0.5)',
                        borderColor: 'rgba(54, 162, 235, 1)',
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    scales: {
                        y: {
                            beginAtZero: true,
                            max: 100
                        }
                    }
                }
            });

            // Create Completion Rate Chart
            new Chart(document.getElementById('completionChart'), {
                type: 'doughnut',
                data: {
                    labels: students,
                    datasets: [{
                        data: completionRates,
                        backgroundColor: [
                            'rgba(255, 99, 132, 0.5)',
                            'rgba(54, 162, 235, 0.5)',
                            'rgba(255, 206, 86, 0.5)',
                            'rgba(75, 192, 192, 0.5)',
                            'rgba(153, 102, 255, 0.5)'
                        ],
                        borderColor: [
                            'rgba(255, 99, 132, 1)',
                            'rgba(54, 162, 235, 1)',
                            'rgba(255, 206, 86, 1)',
                            'rgba(75, 192, 192, 1)',
                            'rgba(153, 102, 255, 1)'
                        ],
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: {
                            position: 'right'
                        }
                    }
                }
            });
        });

        function exportToExcel() {
            const table = document.getElementById('performanceTable');
            const wb = XLSX.utils.table_to_book(table, { sheet: "Student Performance" });
            XLSX.writeFile(wb, 'StudentPerformance.xlsx');
        }
    </script>
}
