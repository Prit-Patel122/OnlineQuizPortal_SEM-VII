@{
    ViewData["Title"] = "Dashboard";
    var quizzes = ViewBag.Quizzes as List<OnlineQuizPortal.Models.Quiz>;
    var userRole = ViewBag.UserRole as string;
}

<div class="row mb-4">
    <div class="col-12">
        <h2 class="text-primary">
            <i class="fas fa-tachometer-alt me-2"></i>@userRole Dashboard
        </h2>
        <p class="lead">Welcome back! Here's an overview of your quizzes and activities.</p>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card border-primary">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">
                    <i class="fas fa-plus-circle me-2"></i>Quick Actions
                </h5>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a asp-controller="Quiz" asp-action="Create" class="btn btn-primary">
                        <i class="fas fa-plus me-2"></i>Create New Quiz
                    </a>
                    <a asp-controller="Quiz" asp-action="Index" class="btn btn-outline-primary">
                        <i class="fas fa-list me-2"></i>Manage All Quizzes
                    </a>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-md-6">
        <div class="card border-info">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0">
                    <i class="fas fa-info-circle me-2"></i>Statistics
                </h5>
            </div>
            <div class="card-body">
                <div class="row text-center">
                    <div class="col-6">
                        <h3 class="text-primary">@quizzes.Count</h3>
                        <p class="text-muted">Total Quizzes</p>
                    </div>
                    <div class="col-6">
                        <h3 class="text-success">@quizzes.Sum(q => q.Questions.Count)</h3>
                        <p class="text-muted">Total Questions</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card border-secondary">
            <div class="card-header bg-secondary text-white">
                <h5 class="mb-0">
                    <i class="fas fa-list me-2"></i>Recent Quizzes
                </h5>
            </div>
            <div class="card-body">
                @if (quizzes.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Title</th>
                                    <th>Subject</th>
                                    <th>Duration</th>
                                    <th>Questions</th>
                                    <th>Created</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var quiz in quizzes)
                                {
                                    <tr>
                                        <td>
                                            <strong>@quiz.Title</strong>
                                        </td>
                                        <td>
                                            <span class="badge bg-secondary">@quiz.Subject</span>
                                        </td>
                                        <td>@quiz.Duration min</td>
                                        <td>@quiz.Questions.Count</td>
                                        <td>@quiz.QuizId</td>
                                        <td>
                                            <div class="btn-group" role="group">
                                                <a asp-controller="Quiz" asp-action="Edit" asp-route-id="@quiz.QuizId" 
                                                   class="btn btn-sm btn-outline-primary">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <a asp-controller="Quiz" asp-action="Delete" asp-route-id="@quiz.QuizId" 
                                                   class="btn btn-sm btn-outline-danger">
                                                    <i class="fas fa-trash"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-4">
                        <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                        <p class="text-muted">No quizzes created yet. Start by creating your first quiz!</p>
                        <a asp-controller="Quiz" asp-action="Create" class="btn btn-primary">
                            <i class="fas fa-plus me-2"></i>Create Quiz
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
