@model IEnumerable<OnlineQuizPortal.Models.Quiz>

@{
    ViewData["Title"] = "Manage Quizzes";
}

<div class="row mb-4">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center">
            <h2 class="text-primary">
                <i class="fas fa-list me-2"></i>Manage Quizzes
            </h2>
            <a asp-action="Create" class="btn btn-primary">
                <i class="fas fa-plus me-2"></i>Create New Quiz
            </a>
        </div>
    </div>
</div>

@if (Model.Any())
{
    <div class="card shadow">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>Title</th>
                            <th>Subject</th>
                            <th>Duration</th>
                            <th>Questions</th>
                            <th>Total Marks</th>
                            <th>Status</th>
                            <th>Created</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var quiz in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@quiz.Title</strong>
                                </td>
                                <td>
                                    <span class="badge bg-secondary">@quiz.Subject</span>
                                </td>
                                <td>@quiz.Duration min</td>
                                <td>
                                    <span class="badge bg-info">@quiz.Questions.Count</span>
                                </td>
                                <td>@quiz.TotalMarks</td>
                                <td>
                                    <span class="badge bg-success">Active</span>
                                </td>
                                <td>@quiz.QuizId</td>
                                <td>
                                    <div class="btn-group" role="group">
                                        <a asp-action="Edit" asp-route-id="@quiz.QuizId" 
                                           class="btn btn-sm btn-outline-primary" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@quiz.QuizId" 
                                           class="btn btn-sm btn-outline-danger" title="Delete">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else
{
    <div class="card shadow">
        <div class="card-body text-center py-5">
            <i class="fas fa-inbox fa-4x text-muted mb-4"></i>
            <h4 class="text-muted">No quizzes created yet</h4>
            <p class="text-muted">Start by creating your first quiz to get started.</p>
            <a asp-action="Create" class="btn btn-primary btn-lg">
                <i class="fas fa-plus me-2"></i>Create Your First Quiz
            </a>
        </div>
    </div>
}
