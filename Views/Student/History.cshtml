@model List<OnlineQuizPortal.ViewModels.QuizHistoryViewModel>
@{
    ViewData["Title"] = "My Quiz History";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-history me-2"></i>My Quiz History</h2>
    <a asp-action="Index" class="btn btn-outline-primary">
        <i class="fas fa-arrow-left me-2"></i>Back to Quizzes
    </a>
</div>

@if (Model != null && Model.Any())
{
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <h6 class="card-title">Total Quizzes Attempted</h6>
                    <h3 class="mb-0">@Model.Count()</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <h6 class="card-title">Completed Quizzes</h6>
                    <h3 class="mb-0">@Model.Count(r => r.IsCompleted)</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-white">
                <div class="card-body">
                    <h6 class="card-title">Average Score</h6>
                    <h3 class="mb-0">@(Model.Any(r => r.IsCompleted) ? Model.Where(r => r.IsCompleted).Average(r => r.Percentage).ToString("F1") : "0")%</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white">
                <div class="card-body">
                    <h6 class="card-title">Best Score</h6>
                    <h3 class="mb-0">@(Model.Any(r => r.IsCompleted) ? Model.Where(r => r.IsCompleted).Max(r => r.Percentage).ToString("F1") : "0")%</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h5 class="mb-0"><i class="fas fa-list me-2"></i>Quiz Results</h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>Quiz Details</th>
                            <th>Performance</th>
                            <th>Time</th>
                            <th>Score</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var result in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex flex-column">
                                        <strong class="mb-1">@result.QuizTitle</strong>
                                        <small class="text-muted">@result.Subject</small>
                                        <span class="badge @(result.IsCompleted ? "bg-success" : "bg-warning") mt-1" style="width: fit-content">
                                            @(result.IsCompleted ? result.Status : "In Progress")
                                        </span>
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex flex-column">
                                        <span>Questions: @result.AttemptedQuestions/@result.TotalQuestions</span>
                                        <span>Correct: @result.CorrectAnswers</span>
                                        @if (result.IsCompleted)
                                        {
                                            <div class="progress mt-2" style="height: 5px; width: 100px;">
                                                <div class="progress-bar @(result.Percentage >= 60 ? "bg-success" : "bg-warning")" 
                                                     role="progressbar" style="width: @result.Percentage%"></div>
                                            </div>
                                        }
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex flex-column">
                                        <small>Started: @result.StartedAt.ToString("MMM dd, yyyy HH:mm")</small>
                                        @if (result.IsCompleted)
                                        {
                                            <small>Time Taken: @result.TimeTaken.ToString("F1") min</small>
                                        }
                                    </div>
                                </td>
                                <td>
                                    @if (result.IsCompleted)
                                    {
                                        <div class="d-flex flex-column">
                                            <strong class="@(result.Percentage >= 60 ? "text-success" : "text-warning")">
                                                @result.Score/@result.TotalMarks
                                            </strong>
                                            <small>@result.Percentage.ToString("F1")%</small>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group">
                                        @if (result.IsCompleted)
                                        {
                                            <a asp-action="Result" asp-route-resultId="@result.ResultId" 
                                               class="btn btn-sm btn-info" title="View Result">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a asp-action="Attempt" asp-route-id="@result.QuizId" 
                                               class="btn btn-sm btn-primary" title="Retake Quiz">
                                                <i class="fas fa-redo-alt"></i>
                                            </a>
                                        }
                                        else
                                        {
                                            <a asp-action="Attempt" asp-route-id="@result.QuizId" 
                                               class="btn btn-sm btn-warning" title="Continue Quiz">
                                                <i class="fas fa-play"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="card-body text-center p-5">
            <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
            <h4 class="text-muted">No Quiz History</h4>
            <p class="text-muted mb-4">You haven't attempted any quizzes yet.</p>
            <a asp-action="Index" class="btn btn-primary">
                <i class="fas fa-list me-2"></i>View Available Quizzes
            </a>
        </div>
    </div>
}
